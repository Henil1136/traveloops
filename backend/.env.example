# ──────────────────────────────────────────────
#  Traveloop Backend — Environment Variables
# ──────────────────────────────────────────────

# MongoDB connection string
# Local:   mongodb://localhost:27017/traveloop
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/traveloop
MONGO_URI=mongodb://localhost:27017/traveloop

# JWT secret (change this to a long random string in production)
JWT_SECRET=traveloop_super_secret_key_change_me_in_production

# JWT expiry duration
JWT_EXPIRES_IN=7d

# Server port
PORT=5000

# Node environment  (development | production)
NODE_ENV=development

# API Ninjas city search key
# Get your free key at https://api.api-ninjas.com/
NINJA_API_KEY=https://api.api-ninjas.com/v1/city

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
